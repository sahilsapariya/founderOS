# Supabase — Project Settings → API Keys (new key format)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=            # server-only, never NEXT_PUBLIC_

# Same values, exposed to the Next.js client bundle (publishable key is
# designed to be public; RLS protects all data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase CLI (for `supabase link` / `db push` from this machine)
# Create at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# OAuth providers — client credentials from Google Cloud Console / GitHub
# Developer Settings; redirect URL is https://<ref>.supabase.co/auth/v1/callback
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_SECRET=
SUPABASE_AUTH_GITHUB_CLIENT_ID=
SUPABASE_AUTH_GITHUB_SECRET=

# --- AI provider (any OpenAI-compatible API) — pick ONE preset ---
#
# Option A — Google Gemini (FREE tier, recommended)
#   Key: https://aistudio.google.com/apikey
#   AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#   AI_MODEL=gemini-2.5-flash
#
# Option B — Groq (free tier, very fast Llama models)
#   Key: https://console.groq.com/keys
#   AI_BASE_URL=https://api.groq.com/openai/v1
#   AI_MODEL=llama-3.3-70b-versatile
#
# Option C — OpenAI (paid)
#   Leave AI_BASE_URL empty; AI_MODEL=gpt-4o-mini
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
